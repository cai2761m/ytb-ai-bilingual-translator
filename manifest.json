{
  "manifest_version": 3,
  "name": "ytb-ai-bilingual-translator",
  "version": "0.1.0",
  "description": "ytb-ai-bilingual-translator",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["src/shared.js", "src/content.js"],
      "css": ["src/overlay.css"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/page-bridge.js"],
      "matches": ["https://www.youtube.com/*"]
    }
  ],
  "options_page": "options/options.html",
  "action": {
    "default_title": "ytb-ai-bilingual-translator"
  }
}
