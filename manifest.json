{
  "manifest_version": 3,
  "name": "AuraTranslate",
  "version": "0.1.0",
  "description": "AuraTranslate - AI bilingual subtitles and immersive webpage translation",
  "permissions": ["storage"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://*/*",
    "http://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["src/shared.js", "src/content.js"],
      "css": ["src/overlay.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/shared.js", "src/immersive.js"],
      "css": ["src/immersive.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/page-bridge.js"],
      "matches": ["https://www.youtube.com/*"]
    }
  ],
  "options_page": "options/options.html",
  "action": {
    "default_title": "AuraTranslate",
    "default_popup": "popup/popup.html"
  }
}
